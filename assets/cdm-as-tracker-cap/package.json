{
  "name": "cdm-as-tracker-cap",
  "version": "1.0.0",
  "private": true,
  "workspaces": ["ui"],
  "dependencies": {
    "@sap/cds": "^9",
    "express": "^4"
  },
  "devDependencies": {
    "@cap-js/cds-test": "^1",
    "jest": "^29"
  },
  "scripts": {
    "start": "cds-serve",
    "dev:cap": "cds watch",
    "dev:ui": "npm run dev --workspace=ui",
    "build": "npm run build --workspace=ui",
    "preview": "npm run build --workspace=ui && cds watch",
    "test": "jest --forceExit",
    "postinstall": "node -e \"const {existsSync,symlinkSync,rmSync}=require('fs'); const t='node_modules/@cap-js/sqlite'; if(existsSync(t)){rmSync(t,{recursive:true,force:true})}; symlinkSync('/usr/local/lib/node_modules/@sap/cds-dk/node_modules/@cap-js/sqlite',t,'junction'); console.log('Linked @cap-js/sqlite from global cds-dk');\""
  },
  "jest": {
    "testEnvironment": "node",
    "testTimeout": 30000
  },
  "cds": {
    "requires": {
      "auth": {
        "kind": "dummy",
        "users": {
          "alex": {
            "password": "alex",
            "roles": ["CDM"]
          },
          "morgan": {
            "password": "morgan",
            "roles": ["CDM", "Manager"]
          },
          "pricingadmin": {
            "password": "pricingadmin",
            "roles": ["Admin"]
          }
        }
      }
    }
  }
}
